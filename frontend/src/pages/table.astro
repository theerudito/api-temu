---
import MainLayout from "../layouts/main.astro";
---

<MainLayout title="Totales por Comprador">
  <div class="p-4 space-y-6">
    <div
      id="global-error"
      class="hidden p-4 rounded-md bg-red-100 text-red-700 border border-red-200"
    >
    </div>

    <section>
      <h2 class="text-xl font-bold mb-4">Totales por Comprador</h2>
      <div class="overflow-x-auto rounded-lg border border-gray-200 shadow-sm">
        <table class="min-w-full text-sm bg-white">
          <thead class="bg-gray-50 border-b">
            <tr>
              <th class="px-4 py-3 text-left font-semibold text-gray-700"
                >Comprador</th
              >
              <th class="px-4 py-3 text-left font-semibold text-gray-700"
                >Pedidos</th
              >
              <th class="px-4 py-3 text-left font-semibold text-gray-700"
                >Envío (Share)</th
              >
              <th class="px-4 py-3 text-left font-semibold text-gray-700"
                >Total con envío</th
              >
            </tr>
          </thead>
          <tbody id="totales-body" class="divide-y divide-gray-100">
            <tr>
              <td colspan="4" class="p-8 text-center text-gray-500 italic"
                >Calculando totales...</td
              >
            </tr>
          </tbody>
          <tfoot id="totales-foot" class="bg-gray-50 border-t hidden"> </tfoot>
        </table>
      </div>
    </section>
  </div>
</MainLayout>

<script>
  interface Comprador {
    id?: number;
    id_comprador?: number;
    nombre?: string;
    name?: string;
    first_name?: string;
    last_name?: string;
    comprador?: string;
    username?: string;
    email?: string;
  }

  interface Pedido {
    id_pedido: number;
    precio?: number | string;
    cantidad?: number | string;
    id_comprador?: number | null;
  }

  interface RowData {
    id: string | number;
    name: string;
    total: number;
    count: number;
    envio: number;
    totalConEnvio: number;
  }

  const serverBaseUrl = "http://192.168.3.16:1000/api/v1";
  const apiCompradores = `${serverBaseUrl}/comprador`;
  const apiPedidos = `${serverBaseUrl}/pedidos`;
  const SHIPPING_COST = 20;
  function getCompradorLabel(cmp: Comprador) {
    return (
      cmp.nombre ||
      cmp.name ||
      [cmp.first_name, cmp.last_name].filter(Boolean).join(" ") ||
      cmp.comprador ||
      cmp.username ||
      cmp.email ||
      `ID: ${cmp.id ?? cmp.id_comprador}`
    );
  }

  function formatPrice(v: number) {
    return Number.isFinite(v)
      ? new Intl.NumberFormat("en-US", {
          style: "currency",
          currency: "USD",
        }).format(v)
      : "$0.00";
  }

  async function calcularYRenderizar() {
    const tbody = document.getElementById("totales-body");
    const tfoot = document.getElementById("totales-foot");
    const errorDiv = document.getElementById("global-error");

    if (!tbody || !tfoot) return;

    try {
      const [compRes, pedRes] = await Promise.all([
        fetch(apiCompradores),
        fetch(apiPedidos),
      ]);

      if (!compRes.ok) throw new Error(`Error Compradores: ${compRes.status}`);
      if (!pedRes.ok) throw new Error(`Error Pedidos: ${pedRes.status}`);

      const compradores: Comprador[] = await compRes.json();
      const pedidosRaw = await pedRes.json();
      const pedidos: Pedido[] = Array.isArray(pedidosRaw)
        ? pedidosRaw
        : pedidosRaw
          ? [pedidosRaw]
          : [];
      const totalsByComprador: Record<
        string,
        { total: number; count: number }
      > = {};

      pedidos.forEach((p) => {
        const cid = p.id_comprador;
        if (cid === null || cid === undefined || String(cid) === "") return;

        const precio = Number(p.precio) || 0;
        const cantidad = Number(p.cantidad) || 0;
        const lineTotal = precio * cantidad;
        const key = String(cid);

        if (!totalsByComprador[key]) {
          totalsByComprador[key] = { total: 0, count: 0 };
        }
        totalsByComprador[key].total += lineTotal;
        totalsByComprador[key].count += 1;
      });
      let rows: RowData[] = compradores
        .map((cmp) => {
          const id = cmp.id ?? cmp.id_comprador ?? 0;
          const bucket = totalsByComprador[String(id)] || {
            total: 0,
            count: 0,
          };
          return {
            id: id,
            name: getCompradorLabel(cmp),
            total: bucket.total,
            count: bucket.count,
            envio: 0,
            totalConEnvio: 0,
          };
        })
        .filter((r) => r.count > 0)
        .sort((a, b) => b.total - a.total);

      const buyersWithOrders = rows.length;
      const shippingShare =
        buyersWithOrders > 0 ? SHIPPING_COST / buyersWithOrders : 0;
      rows = rows.map((r) => ({
        ...r,
        envio: shippingShare,
        totalConEnvio: r.total + shippingShare,
      }));
      tbody.innerHTML = "";
      if (rows.length === 0) {
        tbody.innerHTML = `<tr><td colspan="4" class="p-8 text-center text-gray-400">No hay pedidos asignados.</td></tr>`;
      } else {
        rows.forEach((r) => {
          const tr = document.createElement("tr");
          tr.className = "hover:bg-gray-50 transition-colors";
          tr.innerHTML = `
                <td class="px-4 py-3 text-gray-800 font-medium">${r.name}</td>
                <td class="px-4 py-3 text-gray-600">${r.count}</td>
                <td class="px-4 py-3 text-gray-900">${formatPrice(r.envio)}</td>
                <td class="px-4 py-3 text-gray-900 font-semibold">${formatPrice(r.totalConEnvio)}</td>
            `;
          tbody.appendChild(tr);
        });
      }
      const totalPedidos = rows.reduce((acc, r) => acc + r.count, 0);
      const grandTotalConEnvio = rows.reduce(
        (acc, r) => acc + r.totalConEnvio,
        0,
      );
      const totalEnvioMostrar = buyersWithOrders > 0 ? SHIPPING_COST : 0;
      tfoot.innerHTML = `
        <tr>
            <td class="px-4 py-3 text-gray-700 font-semibold">Total general</td>
            <td class="px-4 py-3 text-gray-600">${totalPedidos}</td>
            <td class="px-4 py-3 text-gray-900">${formatPrice(totalEnvioMostrar)}</td>
            <td class="px-4 py-3 text-gray-900 font-bold">${formatPrice(grandTotalConEnvio)}</td>
        </tr>
      `;
      tfoot.classList.remove("hidden");
    } catch (e: any) {
      console.error(e);
      tbody.innerHTML = `<tr><td colspan="4" class="p-4 text-center text-red-500">Error cargando totales.</td></tr>`;
      if (errorDiv) {
        errorDiv.textContent = e.message || "Error desconocido";
        errorDiv.classList.remove("hidden");
      }
    }
  }
  calcularYRenderizar();
</script>
