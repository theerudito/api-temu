---
import MainLayout from "../layouts/main.astro";
---

<MainLayout title="Compradores">
  <div class="p-6 space-y-8">
    
    <div id="global-error" class="hidden p-4 rounded-md bg-red-100 text-red-700 border border-red-200"></div>

    <section>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
        <div class="flex items-center justify-between mb-2">
          <h2 class="text-xl font-bold">Agregar Comprador</h2>
          <button
            id="btn-crear-comprador"
            type="button"
            class="px-4 py-2 rounded-md bg-blue-600 text-white font-semibold hover:bg-blue-700 transition"
            >Crear</button
          >
        </div>
        <div class="space-y-3 mb-3">
          <label for="cmp-input" class="block text-sm text-gray-700"
            >Nombre del comprador</label
          >
          <input
            id="cmp-input"
            type="text"
            placeholder="Ej: Rodrigo"
            class="w-full rounded-md border border-slate-300 px-3 py-2 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          />
        </div>
        <div class="flex items-center gap-3">
          <span id="crear-comprador-feedback" class="text-sm"></span>
        </div>
      </div>
    </section>

    <section>
      <div class="bg-white rounded-xl border border-slate-200 shadow-sm p-6">
        <h3 class="text-lg font-semibold mb-3">Compradores existentes</h3>
        
        <ul id="lista-compradores" class="list-disc pl-6 space-y-2">
            <li class="text-gray-500 italic">Cargando compradores...</li>
        </ul>
      </div>
    </section>
  </div>
</MainLayout>

<script>
  const serverBaseUrl = "http://192.168.3.16:8000/api/v1";
  const apiCompradores = `${serverBaseUrl}/comprador`;
  const apiCrearComprador = `${serverBaseUrl}/comprador`; 
  const apiEliminarCompradorBase = `${serverBaseUrl}/comprador`; 

  function getCompradorLabel(cmp: any) {
    return (
      cmp.nombre ||
      cmp.name ||
      [cmp.first_name, cmp.last_name].filter(Boolean).join(" ") ||
      cmp.comprador ||
      cmp.username ||
      cmp.email ||
      `ID: ${cmp.id}`
    );
  }

  function crearElementoLista(cmp: any) {
    const li = document.createElement("li");
    const id = cmp.id ?? cmp.id_comprador ?? '';
    
    li.setAttribute("data-id", String(id));
    li.className = "flex items-center gap-3";
    
    li.innerHTML = `
      <span class="cmp-name">${getCompradorLabel(cmp)}</span>
      <button class="btn-edit text-xs px-2 py-1 rounded border border-slate-300 hover:bg-slate-50">Editar</button>
      <button class="btn-delete text-xs px-2 py-1 rounded border border-red-300 text-red-700 hover:bg-red-50">Eliminar</button>
    `;
    return li;
  }

  async function cargarCompradores() {
    const lista = document.getElementById("lista-compradores");
    const errorDiv = document.getElementById("global-error");
    
    if (!lista) return; 

    try {
      const res = await fetch(apiCompradores);
      if (!res.ok) throw new Error(`Error al cargar: ${res.status}`);
      
      let data = await res.json();
      lista.innerHTML = ''; 

      if (Array.isArray(data) && data.length > 0) {
        data.forEach((cmp: any) => {
            lista.appendChild(crearElementoLista(cmp));
        });
      } else {
        lista.innerHTML = '<li class="text-gray-500">No hay compradores aún.</li>';
      }

    } catch (e: any) {
      console.error(e);
      if(errorDiv) {
        errorDiv.textContent = e?.message || "Error desconocido";
        errorDiv.classList.remove('hidden');
      }
      lista.innerHTML = '<li class="text-red-500">Error cargando datos.</li>';
    }
  }

  cargarCompradores();

  document.addEventListener("click", async (e) => {
    const target = e.target as HTMLElement;
    if (!target) return;

    const topBtn = target.closest("#btn-crear-comprador") as HTMLButtonElement | null;
    const editBtn = target.closest(".btn-edit") as HTMLButtonElement | null;
    const deleteBtn = target.closest(".btn-delete") as HTMLButtonElement | null;

    if (deleteBtn) {
      const li = deleteBtn.closest("li");
      if (!li) return;

      const id = Number(li.getAttribute("data-id") || 0);
      const feedback = document.getElementById("crear-comprador-feedback");
      
      if (!id) return;

      const nombreEl = li.querySelector('.cmp-name');
      const nombre = nombreEl ? nombreEl.textContent?.trim() : '';
      const confirmar = window.confirm(`¿Eliminar comprador "${nombre}"?`);
      
      if (!confirmar) return;

      try {
        deleteBtn.disabled = true;
        if (feedback) { feedback.textContent = "Eliminando…"; feedback.className = "text-sm text-gray-600"; }
        
        const res = await fetch(`${apiEliminarCompradorBase}/${id}`, { method: "DELETE" });
        
        if (!res.ok) throw new Error("No se pudo eliminar");
        
        li.remove();
        if (feedback) { feedback.textContent = "Comprador eliminado"; feedback.className = "text-sm text-green-600"; }

        const btn = document.getElementById("btn-crear-comprador") as HTMLButtonElement | null;
        const input = document.getElementById("cmp-input") as HTMLInputElement | null;
        
        if (btn && btn.dataset.editId === String(id)) {
          delete btn.dataset.mode;
          delete btn.dataset.editId;
          btn.textContent = "Crear";
          if (input) input.value = "";
        }

      } catch (err: any) {
        if (feedback) { feedback.textContent = err.message || "Error"; feedback.className = "text-sm text-red-600"; }
      } finally {
        deleteBtn.disabled = false;
      }
      return;
    }

    if (editBtn) {
      const li = editBtn.closest("li");
      if (!li) return;

      const id = li.getAttribute("data-id");
      const nameEl = li.querySelector(".cmp-name");
      const name = nameEl ? nameEl.textContent?.trim() : "";
      
      const input = document.getElementById("cmp-input") as HTMLInputElement | null;
      const btn = document.getElementById("btn-crear-comprador") as HTMLButtonElement | null;
      const feedback = document.getElementById("crear-comprador-feedback");

      if (input) input.value = name || "";
      if (btn) {
        btn.dataset.mode = "edit";
        if (id) btn.dataset.editId = id;
        btn.textContent = "Actualizar";
      }
      
      if (feedback) { feedback.textContent = `Editando ID: ${id}`; feedback.className = "text-sm text-gray-600"; }
      return;
    }

    // --- CREAR O ACTUALIZAR ---
    if (topBtn) {
        const feedback = document.getElementById("crear-comprador-feedback");
        const input = document.getElementById("cmp-input") as HTMLInputElement | null;
        
        // Safety check para input
        if (!input) return;

        const comprador = input.value.trim();
        
        if (!comprador) {
            if (feedback) { feedback.textContent = "Ingresa el nombre"; feedback.className = "text-sm text-red-600"; }
            return;
        }

        try {
            topBtn.disabled = true; // Funciona gracias al cast HTMLButtonElement
            const isEdit = topBtn.dataset.mode === "edit";
            if (feedback) { feedback.textContent = isEdit ? "Actualizando…" : "Creando…"; feedback.className = "text-sm text-gray-600"; }

            let res;
            if (isEdit) {
                const editId = Number(topBtn.dataset.editId);
                res = await fetch(apiCrearComprador, {
                    method: "PUT",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ id_comprador: editId, nombre: comprador }),
                });
            } else {
                res = await fetch(apiCrearComprador, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ nombre: comprador }),
                });
            }

            const data = await res.json();
            if (!res.ok) throw new Error(data.message || "Error en la operación");

            if (feedback) {
                feedback.textContent = isEdit ? "Actualizado correctamente" : "Creado correctamente";
                feedback.className = "text-sm text-green-600";
            }
            
            input.value = "";
            delete topBtn.dataset.mode;
            delete topBtn.dataset.editId;
            topBtn.textContent = "Crear";

            await cargarCompradores();

        } catch (err: any) {
            console.error(err);
            if (feedback) { feedback.textContent = "Error: " + (err.message || "Desconocido"); feedback.className = "text-sm text-red-600"; }
        } finally {
            topBtn.disabled = false;
        }
    }
  });
</script>